<div class="template-twenty-six-container csmm-main-bg">{% assign t26_bg = s.bgImageUrl %}{% if t26_bg == blank or t26_bg == 'null' %}{% assign t26_bg = 'https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=2070&auto=format&fit=crop' %}{% endif %}<div class="t26-background" >&nbsp;</div>
  <div class="t26-overlay">&nbsp;</div>

  <div class="t26-main-content">
     <div style="text-align: center; margin-bottom: 2rem;">{% if logo_to_show != blank %}<div style="margin-bottom: 2rem; display: flex; justify-content: center; width: 100%;"><img src="{{ logo_to_show }}" alt="Logo" width="200" height="50" loading="lazy" style="height: 50px; width: auto; display: block; margin: 0 auto; object-fit: contain;"></div>{% else %}<div style="margin-bottom: 1.5rem; display: flex; justify-content: center; width: 100%;">
            <svg style="height: 80px; width: 80px; margin: 0 auto; display: block;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#D4A762">
                <path d="M16.2,12.8c-0.3-0.2-0.6-0.3-1-0.3c-0.8,0-1.5,0.3-2.1,0.8c-0.6,0.5-0.9,1.3-0.9,2.1c0,0.8,0.3,1.5,0.8,2.1 c0.5,0.6,1.2,0.9,2.1,0.9c0.8,0,1.5-0.3,2.1-0.8c0.6-0.5,0.9-1.3,0.9-2.1c0-0.5-0.1-1-0.4-1.4C17.3,13.6,16.8,13.1,16.2,12.8z M12,2C6.5,2,2,6.5,2,12s4.5,10,10,10s10-4.5,10-10S17.5,2,12,2z M12,20c-4.4,0-8-3.6-8-8s3.6-8,8-8s8,3.6,8,8 S16.4,20,12,20z M18,10h-4V4h-4v6H6l6,6L18,10z"/>
            </svg>
          </div>{% endif %}<h1 class="t26-title-font">{% if s.title == nil %}Aroma Excellence{% else %}{{ s.title }}{% endif %}</h1>
        <p class="t26-description">{% if s.description == nil %}Our master chefs are preparing a symphony of flavors. Join the waitlist for exclusive opening week reservations.{% else %}{{ s.description }}{% endif %}</p>
     </div>{% if s.countdownDate != blank %}<div class="t26-countdown" id="countdown">
        <div class="t26-countdown-box">
          <div id="days" class="t26-countdown-number">00</div>
          <div class="t26-countdown-label">Days</div>
        </div>
        <div class="t26-countdown-box">
          <div id="hours" class="t26-countdown-number">00</div>
          <div class="t26-countdown-label">Hours</div>
        </div>
        <div class="t26-countdown-box">
          <div id="minutes" class="t26-countdown-number">00</div>
          <div class="t26-countdown-label">Minutes</div>
        </div>
        <div class="t26-countdown-box">
          <div id="seconds" class="t26-countdown-number">00</div>
          <div class="t26-countdown-label">Seconds</div>
        </div>
     </div>{% endif %}<div class="t26-subscription">
        <form class="t26-form">
           <input type="email" placeholder="Enter your email address" class="t26-input" required>
           <button type="submit" class="t26-submit">Notify Me</button>
        </form>
     </div>

     <ul class="t26-social">{% render 'cs-social', s: s %}</ul>
  </div>
</div>

