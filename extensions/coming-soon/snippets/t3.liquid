<div class="template-three-container csmm-main-bg" style="background-image: url('{% if s.bgImageUrl != blank and s.bgImageUrl != 'null' and s.bgImageUrl != '' %}{{ s.bgImageUrl }}{% else %}{{ 'temp-3.png' | asset_url }}{% endif %}');">
  <div class="grid-overlay"></div>
  <div class="home-content">
    <div class="home-content__main">{% if logo_to_show != blank %}<div class="home-logo"><img src="{{ logo_to_show }}" alt="Logo" width="200" height="200" loading="lazy"></div>{% endif %}<h1>{% if s.title == nil %}Coming Soon{% else %}{{ s.title }}{% endif %}</h1>
      
      <div class="home-content__video">
        <a class="video-link" href="#" {% if s.watchVideoUrl != blank %}onclick="openeT3VideoModal(event, '{{ s.watchVideoUrl }}')"{% endif %}>
          <span class="video-icon"></span>
          <span class="video-text">Watch Video</span>
        </a>
      </div>
      
      {% if s.watchVideoUrl != blank %}
      <div id="t3-video-modal" class="t3-modal">
        <div class="t3-modal-content">
          <div class="t3-modal-close-container">
             <span class="t3-close-btn" onclick="closeT3VideoModal()">&times;</span>
          </div>
          <iframe id="t3-video-frame" src="" frameborder="0" allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>
        </div>
      </div>
      <script>
        function openeT3VideoModal(e, url) {
          e.preventDefault();
          let embedUrl = url;
          if(url.includes('youtube.com/watch?v=')) {
            embedUrl = url.replace('watch?v=', 'embed/') + '?autoplay=1';
          } else if(url.includes('youtu.be/')) {
            embedUrl = url.replace('youtu.be/', 'youtube.com/embed/') + '?autoplay=1';
          }
          const modal = document.getElementById('t3-video-modal');
          const content = modal.querySelector('.t3-modal-content');
          modal.style.display = 'flex';
          void modal.offsetWidth;
          modal.style.opacity = '1';
          content.style.transform = 'scale(1)';
          document.getElementById('t3-video-frame').src = embedUrl;
        }
        function closeT3VideoModal() {
          const modal = document.getElementById('t3-video-modal');
          const content = modal.querySelector('.t3-modal-content');
          modal.style.opacity = '0';
          content.style.transform = 'scale(0.95)';
          setTimeout(() => {
            modal.style.display = 'none';
            document.getElementById('t3-video-frame').src = '';
          }, 300);
        }
      </script>
      {% endif %}
<h3>{% if s.countdownTitle == nil %}Launching In...{% else %}{{ s.countdownTitle }}{% endif %}</h3>
      <div class="home-content__counter">
        <div class="home-content__clock">
          <div class="time days" id="days">00 <span>D</span></div>
          <div class="time hours" id="hours">00 <span>H</span></div>
          <div class="time minutes" id="minutes">00 <span>M</span></div>
          <div class="time seconds" id="seconds">00 <span>S</span></div>
        </div>
      </div>
    </div>
  </div>

  <ul class="home-social">{% render 'cs-social', s: s %}</ul>
</div>
