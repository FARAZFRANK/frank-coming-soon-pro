{%- for link in s.socialLinks -%}
  {%- assign platform = link[0] | downcase -%}
  {%- assign url = link[1] -%}
  {%- if url != blank -%}
    <li><a href="{{ url }}">
      {%- if platform == 'facebook' -%}{{ fb }}
      {%- elsif platform == 'twitter' or platform == 'x' -%}{{ tw }}
      {%- elsif platform == 'instagram' -%}{{ ig }}
      {%- elsif platform == 'youtube' -%}{{ yt }}
      {%- elsif platform == 'tiktok' -%}{{ tk }}
      {%- elsif platform == 'linkedin' -%}{{ li }}
      {%- elsif platform == 'pinterest' -%}{{ pn }}
      {%- elsif platform == 'whatsapp' -%}{{ wa }}
      {%- endif -%}
    </a></li>
  {%- endif -%}
{%- endfor -%}
