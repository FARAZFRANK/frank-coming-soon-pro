<div class="template-twenty-four-container csmm-main-bg">
  <div class="t24-background-shapes">
     <div class="t24-shape t24-shape1"></div>
     <div class="t24-shape t24-shape2"></div>
     <div class="t24-shape t24-shape3"></div>
     <div class="t24-shape t24-shape4"></div>
     <div class="t24-shape t24-shape5"></div>
  </div>

  <div class="t24-main-content">
     <div class="t24-top-section">
        {% if logo_to_show != blank %}
          <div class="t24-logo-container">
            <img src="{{ logo_to_show }}" alt="Logo" class="t24-logo-img" width="200" height="100" loading="lazy">
          </div>
        {% else %}
          <div class="t24-logo-container">
            <svg class="t24-logo-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="10" stroke="#007AFF" stroke-width="1.5"/>
                <path d="M8 14s1.5 2 4 2 4-2 4-2" stroke="#007AFF" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M9 9.5c0-.828.672-1.5 1.5-1.5s1.5.672 1.5 1.5c0 .829-.672 1.5-1.5 1.5S9 10.329 9 9.5z" fill="#007AFF"/>
                <path d="M13.5 9.5c0-.828.672-1.5 1.5-1.5s1.5.672 1.5 1.5c0 .829-.672 1.5-1.5 1.5s-1.5-.671-1.5-1.5z" fill="#007AFF"/>
            </svg>
          </div>
        {% endif %}
        <h1 class="t24-title-font t24-title"><span class="t24-highlight">{% if s.title == nil %}Level Up Your Skills{% else %}{{ s.title }}{% endif %}</span></h1>
        <p class="t24-desc">{% if s.description == nil %}Our new online learning platform is coming soon. Sign up for early access and exclusive discounts.{% else %}{{ s.description }}{% endif %}</p>
     </div>

     {% if s.countdownDate != blank %}
     <div class="t24-countdown" id="countdown">
        <div class="t24-countdown-box">
          <div id="days" class="t24-countdown-number">00</div>
          <div class="t24-countdown-label">Days</div>
        </div>
        <div class="t24-countdown-box">
          <div id="hours" class="t24-countdown-number">00</div>
          <div class="t24-countdown-label">Hours</div>
        </div>
        <div class="t24-countdown-box">
          <div id="minutes" class="t24-countdown-number">00</div>
          <div class="t24-countdown-label">Minutes</div>
        </div>
        <div class="t24-countdown-box">
          <div id="seconds" class="t24-countdown-number">00</div>
          <div class="t24-countdown-label">Seconds</div>
        </div>
     </div>
     {% endif %}

     <div class="t24-features">
        <div class="t24-feature-box">
          <div class="t24-feature-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="t24-title-font t24-feature-title">Expert-Led Courses</h3>
          <p class="t24-feature-desc">Learn from industry professionals and certified experts.</p>
        </div>
        <div class="t24-feature-box">
          <div class="t24-feature-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
          </div>
          <h3 class="t24-title-font t24-feature-title">Interactive Learning</h3>
          <p class="t24-feature-desc">Engage with quizzes, projects, and hands-on activities.</p>
        </div>
        <div class="t24-feature-box">
          <div class="t24-feature-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
          </div>
          <h3 class="t24-title-font t24-feature-title">Community Support</h3>
          <p class="t24-feature-desc">Connect with peers and mentors in our vibrant community.</p>
        </div>
     </div>

     <div class="t24-subscription">
        <p class="t24-form-prompt">Get notified when we launch!</p>
        <form class="t24-form">
           <input type="email" placeholder="Enter your email address" class="t24-input" required>
           <button type="submit" class="t24-submit">Notify Me</button>
        </form>
     </div>

     <ul class="t24-social">{% render 'cs-social', s: s %}</ul>
  </div>
</div>


